{
  "version": "2.0",
  "config": {
    "minConfidenceScore": 3,
    "showMatchReasons": true,
    "maxSkillsToShow": 3
  },
  "scoring": {
    "keyword": 2,
    "keywordPattern": 3,
    "pathPattern": 4,
    "directoryMatch": 5,
    "intentPattern": 4,
    "contentPattern": 3,
    "contextPattern": 2
  },
  "directoryMappings": {
    ".claude/skills": "kb-audit"
  },
  "skills": {
    "kb-audit": {
      "description": "Audits the knowledge base, scores the repo on four dimensions (/100), and surfaces top-3 gaps. Read-only except for the optional audit save.",
      "priority": 8,
      "triggers": {
        "keywords": [
          "kb audit", "audit the kb", "knowledge base audit", "audit knowledge base",
          "kb health", "score the repo", "structural review", "audit repo",
          "repo health", "check kb", "run audit", "weekly audit"
        ],
        "keywordPatterns": [
          "\\bkb.{0,5}audit\\b",
          "\\baudit.{0,10}(?:kb|knowledge|repo|base)\\b",
          "\\bkb.{0,5}health\\b",
          "\\brepo.{0,5}(?:health|score|audit)\\b",
          "\\bscore.{0,10}repo\\b"
        ],
        "intentPatterns": [
          "(?:run|do|trigger).{0,15}(?:kb audit|knowledge base audit|repo audit|weekly audit)",
          "(?:check|audit|review|score).{0,20}(?:knowledge base|kb|repo|documentation)"
        ],
        "pathPatterns": [
          "audits/**",
          "member-support/**"
        ]
      }
    },

    "refine-scripts": {
      "description": "Drains raw lesson scripts at lesson-scripts/<program>/ root into refined/ — one cold subagent per script + qa-facts pass. Never renders.",
      "priority": 8,
      "triggers": {
        "keywords": [
          "refine scripts", "refine the scripts", "refine lesson scripts",
          "script refinement", "drain raw scripts", "refinement queue"
        ],
        "keywordPatterns": [
          "\\brefine.{0,15}(?:script|lesson)s?\\b",
          "\\bscript.{0,10}refin"
        ],
        "pathPatterns": [
          "projects/video-production/lesson-scripts/**"
        ]
      }
    },

    "render-lessons": {
      "description": "Builds HyperFrames workspaces from refined/ scripts (stops at the human hyperframe gate) and ships approved hyperframes to MP4/Wistia on explicit 'ship <stem>'.",
      "priority": 8,
      "triggers": {
        "keywords": [
          "render lessons", "render the lessons", "build lesson videos",
          "render queue", "ship the video", "render refined scripts"
        ],
        "keywordPatterns": [
          "\\brender.{0,15}lessons?\\b",
          "\\bship\\b.{0,30}_(?:early-career-boost|career-readiness-accelerator|scla-leadership-program)_",
          "\\bbuild.{0,15}(?:lesson|hyperframe)"
        ],
        "pathPatterns": [
          "projects/video-production/renders-hyperframes/**",
          "projects/video-production/renders-mp4/**"
        ]
      }
    },

    "new-from-template": {
      "description": "Creates a new project folder under projects/ using a greenfield template skeleton.",
      "priority": 7,
      "triggers": {
        "keywords": [
          "new project", "create project", "start project", "new from template",
          "scaffold", "new repo", "greenfield", "project template"
        ],
        "keywordPatterns": [
          "\\bnew.{0,10}project\\b",
          "\\bcreate.{0,10}project\\b",
          "\\bscaffold\\b",
          "\\bgreenfield\\b",
          "\\bnew.{0,10}template\\b"
        ],
        "intentPatterns": [
          "(?:start|create|set up|scaffold).{0,20}(?:new project|project folder|from template)",
          "(?:i want to|i need to|help me).{0,20}(?:start|create).{0,20}project"
        ]
      }
    }
  }
}
