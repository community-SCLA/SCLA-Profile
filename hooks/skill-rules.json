{
  "version": "2.0",
  "config": {
    "minConfidenceScore": 3,
    "showMatchReasons": true,
    "maxSkillsToShow": 3
  },
  "scoring": {
    "keyword": 2,
    "keywordPattern": 3,
    "pathPattern": 4,
    "directoryMatch": 5,
    "intentPattern": 4,
    "contentPattern": 3,
    "contextPattern": 2
  },
  "directoryMappings": {
    ".claude/skills": "kb-audit"
  },
  "skills": {
    "ingest": {
      "description": "Organizes existing repo content into the ops framework structure. Fires automatically when _inbox/INGEST_MANIFEST.md is detected.",
      "priority": 9,
      "triggers": {
        "keywords": [
          "ingest", "import content", "organize content", "consolidate",
          "ingest manifest", "bring in files", "stage content", "inbox"
        ],
        "keywordPatterns": [
          "\\bingest\\b",
          "\\b_inbox\\b",
          "\\bINGEST_MANIFEST\\b",
          "\\bimport.{0,15}content\\b",
          "\\borganize.{0,15}content\\b"
        ],
        "intentPatterns": [
          "(?:run|trigger|start).{0,20}ingest",
          "(?:bring in|import|consolidate).{0,20}(?:content|files|docs)"
        ],
        "pathPatterns": [
          "_inbox/**",
          "_inbox/INGEST_MANIFEST.md"
        ]
      }
    },

    "kb-audit": {
      "description": "Audits the knowledge base, scores the repo on four dimensions (/100), and surfaces top-3 gaps. Read-only except for the optional audit save.",
      "priority": 8,
      "triggers": {
        "keywords": [
          "kb audit", "audit the kb", "knowledge base audit", "audit knowledge base",
          "kb health", "score the repo", "structural review", "audit repo",
          "repo health", "check kb", "run audit", "weekly audit"
        ],
        "keywordPatterns": [
          "\\bkb.{0,5}audit\\b",
          "\\baudit.{0,10}(?:kb|knowledge|repo|base)\\b",
          "\\bkb.{0,5}health\\b",
          "\\brepo.{0,5}(?:health|score|audit)\\b",
          "\\bscore.{0,10}repo\\b"
        ],
        "intentPatterns": [
          "(?:run|do|trigger).{0,15}(?:kb audit|knowledge base audit|repo audit|weekly audit)",
          "(?:check|audit|review|score).{0,20}(?:knowledge base|kb|repo|documentation)"
        ],
        "pathPatterns": [
          "audits/**",
          "scla/knowledge-base/**"
        ]
      }
    },

    "new-from-template": {
      "description": "Creates a new project folder under projects/ using a greenfield template skeleton.",
      "priority": 7,
      "triggers": {
        "keywords": [
          "new project", "create project", "start project", "new from template",
          "scaffold", "new repo", "greenfield", "project template"
        ],
        "keywordPatterns": [
          "\\bnew.{0,10}project\\b",
          "\\bcreate.{0,10}project\\b",
          "\\bscaffold\\b",
          "\\bgreenfield\\b",
          "\\bnew.{0,10}template\\b"
        ],
        "intentPatterns": [
          "(?:start|create|set up|scaffold).{0,20}(?:new project|project folder|from template)",
          "(?:i want to|i need to|help me).{0,20}(?:start|create).{0,20}project"
        ]
      }
    }
  }
}
